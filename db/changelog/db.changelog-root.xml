<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!--
        Table name prefix applied to all application tables.
        Liquibase's own tracking tables (DATABASECHANGELOG, DATABASECHANGELOGLOCK)
        are never prefixed — they are owned by Liquibase, not by this application.

        Override on the command line when needed:
            liquibase -DtablePrefix=other_ update
    -->
    <property name="tablePrefix" value="pubsub_"/>

    <include file="v1_initial_schema.xml" relativeToChangelogFile="true"/>

</databaseChangeLog>
